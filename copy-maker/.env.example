# Google Gemini (copy + Nano Banana images). For `npm run build`, set keys under `copy-maker/` with VITE_ prefix.
# Dev server: `GEMINI_API_KEY` in repo-root `.env` is picked up by the Vite proxy (no VITE_ required for local only).
VITE_GEMINI_API_KEY=
# VITE_GOOGLE_AI_API_KEY=
# VITE_NANO_BANANA_API_KEY=

# Copy: try primary first, then fallback if the request fails (HTTP error, block, or empty text).
# Defaults: gemini-3-pro-preview → gemini-2.5-flash. If Google deprecates an id, set explicit models here.
# VITE_GEMINI_COPY_MODEL_PRIMARY=gemini-3.1-pro-preview
# VITE_GEMINI_COPY_MODEL_FALLBACK=gemini-2.5-flash

# Recommended: one OpenRouter key for both Opus + GPT copy (production needs VITE_ prefix for the browser).
# Local dev: OPENROUTER_API_KEY in repo-root `.env` is enough (Vite proxies `/api/openrouter/*`).
# OPENROUTER_API_KEY=
# VITE_OPENROUTER_API_KEY=
# VITE_OPENROUTER_MODEL_OPUS=anthropic/claude-opus-4.7
# VITE_OPENROUTER_MODEL_OPENAI=openai/gpt-5.2
# VITE_OPENROUTER_HTTP_REFERER=https://yoursite.example
# VITE_OPENROUTER_APP_TITLE=Content OS

# Optional: Opus / OpenAI copy without OpenRouter (dev proxy injects keys from repo-root `.env` without VITE_ prefix).
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# VITE_ANTHROPIC_API_KEY=
# VITE_OPENAI_API_KEY=
# VITE_ANTHROPIC_COPY_MODEL=claude-opus-4-7
# VITE_OPENAI_COPY_MODEL=gpt-5.2

# Nano Banana = Gemini image only. Header "Image" dropdown overrides this when set; env still used as fallback for code paths without a choice:
# VITE_NANO_BANANA_MODEL=gemini-2.5-flash-image

# Optional REST base for production if you proxy Gemini yourself (no trailing slash)
# VITE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com
