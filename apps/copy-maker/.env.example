# Google Gemini — **images only** (Nano Banana). Server injects the key; not bundled in the client.
# Repo-root `.env` (next to `apps/`, `data/`, `scripts/`) or Railway **Variables**:
GEMINI_API_KEY=
# GOOGLE_AI_API_KEY=

# OpenRouter — **all copy** (Opus / GPT / Gemini options in the header). Server only.
OPENROUTER_API_KEY=

# Apify LinkedIn scrape (used by transcript import optional enrichment and CSV import script).
APIFY_TOKEN=
APIFY_LINKEDIN_ACTOR_ID=M2FMdjRVeF1HPGFcc
# Most LinkedIn actors use "profileUrls". Set "startUrls" if your actor expects startUrls objects.
APIFY_LINKEDIN_INPUT_KEY=profileUrls

# Optional: Pass 2 chunk interpretation (rerunnable hypothesis lens).
# If these are set, pipeline writes `chunk_interpretations` rows per transcript.
VANTUM_HYPOTHESIS_VERSION=
VANTUM_HYPOTHESIS_TEXT=
VANTUM_HYPOTHESIS_ICP=
VANTUM_HYPOTHESIS_DIMENSIONS=
