# --- Content OS (GitHub / Railway): keep the repo small and safe ---

# Secrets
.env
.env.*
!.env.example

# Node / build
**/node_modules/
**/dist/
**/build/
*.log
.npm-cache/
.cache/

# Large research tree (transcripts, Playwright profiles, PDFs) — not required for Content OS
# NOTE: data/presentations is intentionally included for live interview/demo library endpoints.

data/generated/
data/presentations/**/__pycache__/
data/presentations/**/*.pyc
data/presentations/claude_browser_batch_md/
data/presentations/claude_web_export/
data/presentations/originals/
data/presentations/originals_txt/
data/presentations/pipeline/jobs/
data/presentations/tools/pw_chrome_profile/

# Outlier pipeline: only the two JSON files the app reads at runtime (see vite-plugin-copy-maker-data)
data/outliers/*
!data/outliers/data/
data/outliers/data/*
!data/outliers/data/outliers_index.json
!data/outliers/data/outlier_framework_cache.json
!data/outliers/data/outliers_swipe_catalog.json

# Railway CLI local link (machine-specific)
.railway/

# Editor / OS noise
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/*
!.vscode/extensions.json
~$*
